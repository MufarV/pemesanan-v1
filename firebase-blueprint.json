{
  "entities": {
    "StoreSettings": {
      "title": "Store Settings",
      "description": "Global settings for the store operations and appearance",
      "type": "object",
      "properties": {
        "menerimaPesanan": { "type": "boolean" },
        "openTime": { "type": "string" },
        "closeTime": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "instagramLink": { "type": "string" },
        "heroText": { "type": "string" },
        "bestSellerImage": { "type": "string" },
        "openPoDates": { "type": "array", "items": { "type": "string" } },
        "poDatesConfig": { "type": "object" },
        "products": { "type": "array" },
        "reviews": { "type": "array" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "customerName": { "type": "string" },
        "tanggal_po": { "type": "string" },
        "waktu_po": { "type": "string" },
        "totalPcs": { "type": "integer" },
        "totalHarga": { "type": "integer" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string", "enum": ["Baru", "Diproses", "Selesai", "Dibatalkan"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "items": { "type": "string" }
      },
      "required": ["ownerId", "customerName", "tanggal_po", "waktu_po", "totalPcs", "status", "createdAt"]
    }
  },
  "firestore": {
    "/pengaturan/pengaturan_toko": {
      "schema": "StoreSettings",
      "description": "Single document for store configuration"
    },
    "/pesanan/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    }
  }
}
